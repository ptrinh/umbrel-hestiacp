#!/usr/bin/env bash
#
# post-start hook
# On the very first start, reset HestiaCP's "admin" password to Umbrel's
# deterministic app password ($APP_PASSWORD) so the credentials shown in the
# Umbrel UI actually work. Runs only once (guarded by a sentinel file) so it
# never clobbers a password the user later changes inside the panel.
#
# The work is detached into the background: HestiaCP's systemd stack can take a
# few minutes to come up on first boot, and we don't want to block app start
# while we wait.

CONTAINER="trinh-hestiacp_hestia_1"
SENTINEL="${APP_DATA_DIR:-.}/.admin-password-set"
# HestiaCP CLI tools aren't on PATH for a non-login `docker exec`, so call them
# by absolute path.
HBIN="/usr/local/hestia/bin"

# Already initialised — nothing to do.
[ -f "$SENTINEL" ] && exit 0

# setsid fully detaches so the loop survives this hook returning.
APP_PASSWORD="${APP_PASSWORD}" setsid bash -c '
  for _ in $(seq 1 120); do
    if docker exec "'"$CONTAINER"'" "'"$HBIN"'/v-list-users" >/dev/null 2>&1; then
      if docker exec "'"$CONTAINER"'" "'"$HBIN"'/v-change-user-password" admin "$APP_PASSWORD"; then
        touch "'"$SENTINEL"'"
        break
      fi
    fi
    sleep 5
  done
' </dev/null >/dev/null 2>&1 &

exit 0
