#!/usr/bin/env bash
#
# post-start hook (privileged smied variant)
#
# 1) Patch the panel's PHP session cookie so login works through Umbrel's
#    plain-HTTP app_proxy. The smied image forces session.cookie_secure=on +
#    SameSite=Strict; the browser drops a Secure cookie over HTTP, so the login
#    bounces back. Idempotent (only patches if still "on"); the change persists
#    in the /usr named volume.
# 2) On first start, set HestiaCP's "admin" password to Umbrel's deterministic
#    $APP_PASSWORD (guarded by a sentinel so a later in-panel change is kept).
#
# Work is detached (setsid) so it doesn't block app start while HestiaCP's
# systemd stack comes up.

CONTAINER="trinh-hestiacp_hestia_1"
SENTINEL="${APP_DATA_DIR:-.}/.admin-password-set"
HBIN="/usr/local/hestia/bin"

# In-container fixer (no host-side interpolation; runs HestiaCP-side).
FIXER="$(mktemp)"
cat > "$FIXER" <<'INNER'
#!/bin/bash
for _ in $(seq 1 120); do /usr/local/hestia/bin/v-list-users >/dev/null 2>&1 && break; sleep 5; done
CONF=/usr/local/hestia/php/etc/php-fpm.conf
if grep -q '^php_admin_flag\[session.cookie_secure\] = on' "$CONF"; then
  sed -i 's/^php_admin_flag\[session.cookie_secure\] = on/php_admin_flag[session.cookie_secure] = off/' "$CONF"
  sed -i 's/^php_admin_value\[session.cookie_samesite\] = "Strict"/php_admin_value[session.cookie_samesite] = "Lax"/' "$CONF"
  systemctl restart hestia 2>/dev/null
fi
INNER

APP_PASSWORD="${APP_PASSWORD}" setsid bash -c '
  docker cp "'"$FIXER"'" "'"$CONTAINER"'":/tmp/hestia-cookie-fix.sh 2>/dev/null
  docker exec "'"$CONTAINER"'" bash /tmp/hestia-cookie-fix.sh 2>/dev/null
  rm -f "'"$FIXER"'"
  if [ ! -f "'"$SENTINEL"'" ]; then
    for _ in $(seq 1 30); do
      if docker exec "'"$CONTAINER"'" "'"$HBIN"'/v-change-user-password" admin "$APP_PASSWORD"; then
        touch "'"$SENTINEL"'"
        break
      fi
      sleep 3
    done
  fi
' </dev/null >/dev/null 2>&1 &

exit 0
