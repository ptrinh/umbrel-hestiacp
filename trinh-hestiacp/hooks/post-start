#!/usr/bin/env bash
#
# post-start hook (privileged smied variant), run synchronously so the work
# reliably completes (a backgrounded/detached child can be torn down when the
# hook returns).
#
# 1) Patch the panel's PHP session cookie so login works through Umbrel's
#    plain-HTTP app_proxy. The smied image forces session.cookie_secure=on +
#    SameSite=Strict; a browser drops a Secure cookie over HTTP, so login
#    bounces. Idempotent; persists in the /usr named volume.
# 2) On first start, set "admin" to Umbrel's deterministic $APP_PASSWORD
#    (sentinel-guarded so a later in-panel change is kept).

CONTAINER="trinh-hestiacp_hestia_1"
SENTINEL="${APP_DATA_DIR:-.}/.admin-password-set"
HBIN="/usr/local/hestia/bin"
CONF="/usr/local/hestia/php/etc/php-fpm.conf"

# Wait (bounded) for HestiaCP to be up.
for _ in $(seq 1 60); do
  docker exec "$CONTAINER" "$HBIN/v-list-users" >/dev/null 2>&1 && break
  sleep 5
done

# Fix the Secure/Strict session cookie (only if still set), then reload the panel.
if docker exec "$CONTAINER" grep -q '^php_admin_flag\[session.cookie_secure\] = on' "$CONF" 2>/dev/null; then
  docker exec "$CONTAINER" sed -i 's/^php_admin_flag\[session.cookie_secure\] = on/php_admin_flag[session.cookie_secure] = off/' "$CONF"
  docker exec "$CONTAINER" sed -i 's/^php_admin_value\[session.cookie_samesite\] = "Strict"/php_admin_value[session.cookie_samesite] = "Lax"/' "$CONF"
  docker exec "$CONTAINER" systemctl restart hestia
fi

# Set the admin password once.
if [ ! -f "$SENTINEL" ]; then
  for _ in $(seq 1 30); do
    if docker exec "$CONTAINER" "$HBIN/v-change-user-password" admin "$APP_PASSWORD"; then
      touch "$SENTINEL"
      break
    fi
    sleep 3
  done
fi

exit 0
